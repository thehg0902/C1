node_modules/
.DS_Store
*.log
.env
agency/client/assets-intake/originals/

# Raw client uploads (unoptimized source photos/video) - the optimized,
# deployable versions are tracked under assets/. Keeping these out of git
# history avoids committing large raw files (e.g. a 65MB source video).
agency/client/assets-intake/*
!agency/client/assets-intake/.gitkeep
